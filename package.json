{
  "name": "skills-copilot-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "dev": "./script/build_and_run.sh",
    "build": "./script/build_and_run.sh --verify",
    "dev:macos": "./script/build_and_run.sh",
    "build:macos": "./script/build_and_run.sh --verify",
    "audit": "pnpm audit:rust && pnpm audit:node",
    "audit:rust": "cargo audit",
    "audit:node": "pnpm audit --audit-level high",
    "check:privacy": "./script/check_privacy.sh",
    "classify:validation-blocker": "node scripts/classify-validation-blocker.mjs",
    "capture:macos-window": "./script/capture_app_window.sh SkillsCopilot docs/ui-artifacts/native-macos-shell/completed.png",
    "check:macos": "cargo fmt --all -- --check && cargo test --workspace && cargo clippy --workspace --all-targets --all-features -- -D warnings && pnpm test:macos-list-model && pnpm verify:macos-ui-layout && pnpm verify:gate-parity && swift test --package-path apps/macos && swift build --package-path apps/macos && ./script/build_and_run.sh --verify && pnpm smoke:macos-app -- --fixture-data --capture-window && pnpm verify:screenshot-artifacts",
    "smoke:macos-app": "node scripts/smoke-macos-app.mjs",
    "verify:screenshot-artifacts": "node scripts/verify-screenshot-artifacts.mjs",
    "verify:validation-blockers": "node scripts/verify-validation-blockers.mjs",
    "verify:v2.73-docs": "node scripts/verify-v2-73-validation-docs.mjs",
    "verify:v2.74-docs": "node scripts/verify-v2-74-validation-docs.mjs",
    "verify:v2.75-docs": "node scripts/verify-v2-75-validation-docs.mjs",
    "verify:v2.76-docs": "node scripts/verify-v2-76-validation-docs.mjs",
    "verify:v2.77-docs": "node scripts/verify-v2-77-validation-docs.mjs",
    "verify:v2.78-docs": "node scripts/verify-v2-78-validation-docs.mjs",
    "verify:v2.79-docs": "node scripts/verify-v2-79-validation-docs.mjs",
    "verify:v2.80-docs": "node scripts/verify-v2-80-validation-docs.mjs",
    "verify:v2.81-docs": "node scripts/verify-v2-81-validation-docs.mjs",
    "verify:v2.82-docs": "node scripts/verify-v2-82-validation-docs.mjs",
    "verify:service-protocol-drift": "node scripts/verify-service-protocol-drift.mjs",
    "verify:gate-parity": "pnpm verify:service-protocol-drift && pnpm verify:v2.73-docs && pnpm verify:v2.74-docs && pnpm verify:v2.75-docs && pnpm verify:v2.76-docs && pnpm verify:v2.77-docs && pnpm verify:v2.78-docs && pnpm verify:v2.79-docs && pnpm verify:v2.80-docs && pnpm verify:v2.81-docs && pnpm verify:v2.82-docs && pnpm verify:validation-blockers && pnpm verify:screenshot-artifacts",
    "benchmark:10k": "node scripts/benchmark-10k.mjs",
    "test:macos-list-model": "node scripts/test-native-list-model.mjs",
    "benchmark:macos-list-model": "node scripts/benchmark-native-list-model.mjs",
    "verify:macos-ui-layout": "node scripts/verify-native-ui-layout.mjs"
  }
}
